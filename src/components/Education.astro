---
interface Props {
  education: any[];
}

const { education } = Astro.props;
---

<div class="education-list">
  {education.map(e => (
    <div class="education-item reveal">
      <div>
        <div class="education-institution">{e.institution}</div>
        <div class="education-degree">{e.degree}</div>
      </div>
      <div style="text-align:right;flex-shrink:0">
        {e.grade && <div class="education-grade">{e.grade}</div>}
        {e.from && e.to && <div class="education-years">{e.from} – {e.to}</div>}
      </div>
    </div>
  ))}
</div>
