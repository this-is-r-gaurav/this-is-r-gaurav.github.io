---
interface Props {
  header: any;
}

const { header } = Astro.props;
const nameParts = (header.name || 'Your Name').split(' ');
const lastName = nameParts.pop();
const firstName = nameParts.join(' ');
---

<header class="hero">
  <h1 class="hero__name">{firstName} <span>{lastName}</span></h1>
  {header.title && <p class="hero__title">{header.title}</p>}
  {header.tagline && (
    <p class="hero__tagline">
      <span class="hero__typewriter" data-text={header.tagline}></span>
    </p>
  )}

  <div class="hero__links">
    {header.email && (
      <a href={`mailto:${header.email}`} class="hero__link">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
        </svg>
        {header.email}
      </a>
    )}
    {header.phone && (
      <a href={`tel:${header.phone}`} class="hero__link">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13 19.79 19.79 0 0 1 1.61 4.4 2 2 0 0 1 3.6 2.21h3a2 2 0 0 1 2 1.72c.12.96.36 1.91.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.29 6.29l.96-.96a2 2 0 0 1 2.11-.45c.9.34 1.85.58 2.81.7a2 2 0 0 1 1.72 2.03z"/>
        </svg>
        {header.phone}
      </a>
    )}
    {header.github && (
      <a href={`https://${header.github}`} class="hero__link" target="_blank">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
        </svg>
        {header.github}
      </a>
    )}
    {header.location && (
      <span class="hero__link">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
        </svg>
        {header.location}
      </span>
    )}
    {header.home && (
      <span class="hero__link">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
        </svg>
        {header.home}
      </span>
    )}
  </div>
</header>

<script>
  // Typewriter effect
  const twEls = document.querySelectorAll('.hero__typewriter');
  twEls.forEach((el: any) => {
    const text = el.dataset.text;
    if (!text) return;
    let i = 0;
    const speed = 40;
    const iv = setInterval(() => {
      el.textContent += text[i++];
      if (i >= text.length) clearInterval(iv);
    }, speed);
  });

  // Track contact link clicks
  document.querySelectorAll('.hero__links a.hero__link').forEach((link) => {
    link.addEventListener('click', () => {
      const href = (link as HTMLAnchorElement).href;
      const type = href.startsWith('mailto:') ? 'email' : href.startsWith('tel:') ? 'phone' : 'social';
      (window as any).posthog?.capture('contact_link_clicked', { type, href });
    });
  });
</script>
