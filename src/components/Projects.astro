---
interface Props {
  projects: any[];
}

const { projects } = Astro.props;
---

<div class="projects-grid stagger">
  {projects.map(p => (
    <div class="project-card reveal-scale">
      <div class="project-header">
        <div class="project-name">{p.name}</div>
        {p.stars && (
          <div class="project-stars">
            <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg> 
            {p.stars}
          </div>
        )}
      </div>
      {p.description && <p class="project-desc">{p.description}</p>}
      {p.tech && (
        <div class="project-tech">
          {p.tech.map((t: string) => <span class="tech-tag">{t}</span>)}
        </div>
      )}
      {p.url && (
        <a href={`https://${p.url}`} class="project-link" target="_blank">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
          </svg>
          {p.url}
        </a>
      )}
    </div>
  ))}
</div>
