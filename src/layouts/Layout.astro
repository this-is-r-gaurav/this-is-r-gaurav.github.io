---
import yaml from 'js-yaml';
import fs from 'node:fs';
import PostHog from '../components/posthog.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;

// Load full resume data for JSON-LD and SEO
const fileContents = fs.readFileSync("./src/data/resume.yaml", "utf8");
const data = yaml.load(fileContents) as any;

const siteUrl = "https://this-is-r-gaurav.github.io/"; 
const shareImage = `${siteUrl}og-image.png`; 
---

<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description || data.meta.description} />
  <meta name="keywords" content={data.meta.keywords} />
  <meta name="author" content={data.header.name} />
  
  <!-- SEO / Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={siteUrl} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description || data.meta.description} />
  <meta property="og:image" content={shareImage} />

  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:url" content={siteUrl} />
  <meta property="twitter:title" content={title} />
  <meta property="twitter:description" content={description || data.meta.description} />
  <meta property="twitter:image" content={shareImage} />

  <link rel="canonical" href={siteUrl} />

  <!-- JSON-LD -->
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org/",
    "@type": "Person",
    "name": data.header.name,
    "jobTitle": data.header.title,
    "url": siteUrl,
    "sameAs": [
      data.header.github,
      data.header.linkedin
    ],
    "description": data.meta.description,
    "knowsAbout": [
      "Software Engineering",
      "Full Stack Development",
      "Threat Intelligence",
      "Python",
      "Go",
      "Cloud Infrastructure"
    ]
  })} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Fira+Code:wght@400;500&family=EB+Garamond:wght@400;500;600;700;800&display=swap"
    rel="stylesheet"
  />

  <PostHog />
</head>
<body>
  <!-- Loader -->
  <div id="loader" class="loader">
    <div class="loader__spinner"></div>
    <p class="loader__text">Loading resume…</p>
  </div>

  <div id="resume-root" style="opacity:0">
    <slot />
  </div>

  <!-- PDF Toast -->
  <div id="toast" class="toast">Generating PDF…</div>

  <script>
    // Theme Management
    const savedTheme = localStorage.getItem('resume-theme') || 'dark';
    document.documentElement.dataset.theme = savedTheme;

    // Loader Management
    window.addEventListener('DOMContentLoaded', () => {
      const loader = document.getElementById('loader');
      const root = document.getElementById('resume-root');
      if (loader && root) {
        loader.classList.add('hidden');
        root.style.opacity = '1';
        setTimeout(() => loader.remove(), 600);
      }
    });

    // Scroll Reveal
    const initScrollReveal = () => {
      const obs = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            e.target.classList.add('visible');
            obs.unobserve(e.target);
          }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });

      document.querySelectorAll('.reveal, .reveal-left, .reveal-scale').forEach(el => obs.observe(el));
    };

    // Skill Bar Animation
    const initSkillBars = () => {
      const obs = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            const fills = e.target.querySelectorAll('.skill-bar__fill');
            fills.forEach(f => {
              const level = (f as HTMLElement).dataset.level || '80';
              requestAnimationFrame(() => { (f as HTMLElement).style.width = level + '%'; });
            });
            obs.unobserve(e.target);
          }
        });
      }, { threshold: 0.2 });

      document.querySelectorAll('.skill-category__name, .skill-list, #skills').forEach(el => obs.observe(el));
    };

    window.addEventListener('DOMContentLoaded', () => {
      initScrollReveal();
      initSkillBars();
    });
  </script>
</body>
</html>
<style is:global>
  @import "../styles/global.css";
</style>
